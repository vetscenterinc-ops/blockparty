/* ── Open event detail page ───────────────────────────────────────────────
   Called by each registration card's Register button.
   ──────────────────────────────────────────────────────────────────────── */
function openEventPage(cardKey) {
  const data = EVENT_DATA[cardKey];
  if (!data) { openReg(cardKey); return; }

  const day     = (typeof CARD_TO_DAY !== 'undefined') ? CARD_TO_DAY[cardKey] || '' : '';
  const dayCfg  = (typeof EB_DAY_MAP  !== 'undefined') ? EB_DAY_MAP[day]   || {} : {};
  const dayId   = dayCfg.ebId || localStorage.getItem('cbp_eb_id_' + day) || '';
  const globalUrl = localStorage.getItem('cbp_key_eburl') || '';
  const ebUrl   = dayId ? 'https://www.eventbrite.com/e/' + dayId : (globalUrl || '');

  /* Build sponsor cards HTML */
  const sponsorKeys = data.sponsors || ['general'];
  let sponsorCards = '';
  const seen = new Set();
  sponsorKeys.forEach(sk => {
    (SPONSOR_DATA[sk] || []).forEach(sp => {
      if (seen.has(sp.name)) return;
      seen.add(sp.name);
      if (sp.available) {
        sponsorCards += `
        <div class="ep-sponsor-card ep-sponsor-avail" onclick="go('sponsors',document.querySelectorAll('.nav-btn')[2])">
          <div class="ep-spon-logo" style="background:rgba(255,0,160,0.12);color:var(--pink)">${sp.logo}</div>
          <div class="ep-spon-body">
            <div class="ep-spon-tier" style="color:var(--pink)">${sp.tier}</div>
            <div class="ep-spon-name">${sp.name}</div>
            <div class="ep-spon-tagline">${sp.tagline}</div>
            <div class="ep-spon-deal">${sp.deal}</div>
          </div>
          <button class="ep-spon-cta avail-cta">${sp.cta} →</button>
        </div>`;
      } else {
        sponsorCards += `
        <div class="ep-sponsor-card">
          <div class="ep-spon-logo" style="background:${sp.color};color:${sp.textColor}">${sp.logo}</div>
          <div class="ep-spon-body">
            <div class="ep-spon-tier" style="color:${sp.textColor}">${sp.tier}</div>
            <div class="ep-spon-name">${sp.name}</div>
            <div class="ep-spon-tagline">${sp.tagline}</div>
            <div class="ep-spon-deal">${sp.deal}</div>
          </div>
          <span class="ep-spon-badge">Sponsor</span>
        </div>`;
      }
    });
  });

  /* Activities HTML */
  const activitiesHTML = data.activities.map(a => `
    <div class="ep-activity">
      <div class="ep-act-icon">${a.icon}</div>
      <div><div class="ep-act-name">${a.name}</div><div class="ep-act-desc">${a.desc}</div></div>
    </div>`).join('');

  /* Highlights */
  const highlightsHTML = data.highlights.map(h => `<div class="ep-highlight"><i class="ti ti-check"></i>${h}</div>`).join('');

  /* Eventbrite embed / fallback */
  const ebSection = ebUrl ? `
    <div class="ep-eb-frame">
      <iframe src="${ebUrl}" title="Register for ${data.title}" loading="lazy"
        style="width:100%;min-height:580px;border:none;border-radius:12px;"></iframe>
    </div>` : `
    <div class="ep-eb-placeholder">
      <div style="font-size:40px;margin-bottom:12px">🎟️</div>
      <div class="ep-eb-ph-title">Eventbrite Registration</div>
      <p class="ep-eb-ph-body">Your organizer hasn't connected Eventbrite yet. Log in → Organizer → API Keys → paste your Event ID to embed live registration here.</p>
      <a href="https://www.eventbrite.com" target="_blank" rel="noopener" class="ep-reg-btn">Register on Eventbrite →</a>
    </div>`;

  /* Full page HTML */
  const page = document.getElementById('eventDetailPage');
  page.innerHTML = `
    <div class="ep-hero" style="--ep-color:${data.color};--ep-dim:${data.colorDim}">
      <div class="ep-hero-bg"></div>
      <button class="ep-back" onclick="closeEventPage()"><i class="ti ti-arrow-left"></i> Back to Register</button>
      <div class="ep-hero-content">
        <div class="ep-day-badge" style="color:${data.color};border-color:${data.color}">${data.day} · ${data.date}</div>
        <div class="ep-hero-emoji">${data.emoji}</div>
        <h1 class="ep-title">${data.title}</h1>
        <p class="ep-tagline" style="color:${data.color}">${data.tagline}</p>
        <div class="ep-meta-row">
          <span><i class="ti ti-clock"></i> ${data.time}</span>
          <span><i class="ti ti-map-pin"></i> Lovejoy, GA</span>
          <span><i class="ti ti-users"></i> All Ages Welcome</span>
        </div>
      </div>
    </div>

    <div class="ep-body">

      <div class="ep-layout">

        <!-- LEFT: info + activities + sponsors -->
        <div class="ep-left">

          <div class="ep-section">
            <div class="ep-sec-label">About This Event</div>
            <p class="ep-desc">${data.description}</p>
            <div class="ep-highlights">${highlightsHTML}</div>
          </div>

          <div class="ep-section">
            <div class="ep-sec-label">What's Inside</div>
            <div class="ep-activities">${activitiesHTML}</div>
          </div>

          <div class="ep-section">
            <div class="ep-sec-label" style="display:flex;align-items:center;justify-content:space-between">
              <span>Event Sponsors</span>
              <button class="ep-become-spon" onclick="go('sponsors',document.querySelectorAll('.nav-btn')[2])">Become a Sponsor →</button>
            </div>
            <div class="ep-sponsors">${sponsorCards || '<div class="ep-no-spon">No sponsors listed yet — <button class="ep-link-btn" onclick="go(\'sponsors\',document.querySelectorAll(\'.nav-btn\')[2])">Be the first to sponsor this event →</button></div>'}</div>
          </div>

        </div>

        <!-- RIGHT: Eventbrite embed -->
        <div class="ep-right">
          <div class="ep-reg-panel">
            <div class="ep-reg-header">
              <div class="ep-reg-title">Register for This Event</div>
              <div class="ep-reg-sub">Secure checkout powered by Eventbrite</div>
            </div>
            ${ebSection}
            <div class="ep-trust-row">
              <span><i class="ti ti-lock" style="color:var(--green)"></i> SSL Secured</span>
              <span><i class="ti ti-shield-check" style="color:var(--green)"></i> Safe Checkout</span>
              <span><i class="ti ti-refresh" style="color:var(--green)"></i> Instant Confirmation</span>
            </div>
          </div>
        </div>

      </div>
    </div>`;

  const regBtn2 = Array.from(document.querySelectorAll('.nav-btn'))
    .find(b => b.querySelector('i.ti-ticket') || b.textContent.trim().toLowerCase().includes('register'));
  go('eventDetailPage', regBtn2 || null);
}

function closeEventPage() {
  /* Find the Register nav button by its icon class */
  const regBtn = Array.from(document.querySelectorAll('.nav-btn'))
    .find(b => b.querySelector('i.ti-ticket') || b.textContent.trim().toLowerCase().includes('register'));
  go('registration', regBtn || document.querySelectorAll('.nav-btn')[3]);
}
